{# Auto-generated by MockBuilder from the AppModel. Do not edit by hand. #}
import { createContext, useReducer, useContext } from 'react';

// Initial state is seeded deterministically from the AppModel's entities:
// each entity's `seed` rows become a state slice keyed by the entity name.
const initialState = {
{% for entity in entities %}
  "{{ entity.name }}": {{ entity.seed | tojson }},
{% endfor %}
};

// Generic reducer. `action.type` maps to a schema mutation op
// (add | remove | increment | decrement | set | clear | toggle) and
// `action.store` selects the state slice to operate on. No app-specific logic
// lives here - every mock's mutations flow through this one function.
function reducer(state, action) {
  const { type, store, payload } = action;
  const slice = state[store];

  switch (type) {
    case 'add':
      return {
        ...state,
        [store]: [...(Array.isArray(slice) ? slice : []), payload],
      };
    case 'remove':
      return {
        ...state,
        [store]: (Array.isArray(slice) ? slice : []).filter(
          (item) => (item?.id ?? item) !== (payload?.id ?? payload)
        ),
      };
    case 'toggle': {
      const list = Array.isArray(slice) ? slice : [];
      const id = payload?.id ?? payload;
      const exists = list.some((item) => (item?.id ?? item) === id);
      return {
        ...state,
        [store]: exists
          ? list.filter((item) => (item?.id ?? item) !== id)
          : [...list, payload],
      };
    }
    case 'increment':
      return { ...state, [store]: (Number(slice) || 0) + (payload ?? 1) };
    case 'decrement':
      return { ...state, [store]: (Number(slice) || 0) - (payload ?? 1) };
    case 'set':
      return { ...state, [store]: payload };
    case 'clear':
      return { ...state, [store]: Array.isArray(slice) ? [] : null };
    default:
      return state;
  }
}

const GlobalContext = createContext(null);

// Wraps the app, holds the reduced state, and exposes a declarative `mutate`.
export function GlobalProvider({ children }) {
  const [state, dispatch] = useReducer(reducer, initialState);
  // `mutate` takes a declarative action: { type, store, payload }.
  const mutate = (action) => dispatch(action);
  // NB: a named value avoids an inline JSX object literal, whose doubled braces
  // would collide with Jinja's output delimiters in the template.
  const contextValue = { state, mutate };

  return (
    <GlobalContext.Provider value={contextValue}>
      {children}
    </GlobalContext.Provider>
  );
}

// Convenience hook used by generated components/screens.
export function useMockState() {
  const context = useContext(GlobalContext);
  if (context === null) {
    throw new Error('useMockState must be used within a GlobalProvider');
  }
  return context;
}
