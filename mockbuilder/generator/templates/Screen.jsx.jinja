{# Auto-generated by MockBuilder from the AppModel. Do not edit by hand. #}
{% set component_name = screen.id.split('-') | map('capitalize') | join %}
{% set regions = (screen.layout.regions if screen.layout else []) or [] %}
{% set comps = [] %}
{% for region in regions %}
{% for c in region.components or [] %}
{% if c in component_names and c not in comps %}
{% set _ = comps.append(c) %}
{% endif %}
{% endfor %}
{% endfor %}
{% set ns = namespace(needs_state=false) %}
{% for region in regions %}
{% if region.repeats and region.repeatsOver %}
{% set ns.needs_state = true %}
{% endif %}
{% endfor %}
import { useSearchParams } from 'react-router-dom';
{% if ns.needs_state %}
import { Fragment } from 'react';
import { useMockState } from '../GlobalContext';
{% endif %}
{% for c in comps %}
import {{ c }} from '../components/{{ c }}';
{% endfor %}

// {{ screen.name }} ({{ screen.route }})

export default function {{ component_name }}() {
  const [searchParams] = useSearchParams();
  const currentState = searchParams.get('state') || 'default';
{% if ns.needs_state %}
  const { state } = useMockState();
{% endif %}
{# Fault-tolerant data lookup: accept singular OR plural store keys so a slight
   naming mismatch from a text-only model still resolves the seed array. #}
{% set repeat_entities = [] %}
{% for region in regions %}
{% if region.repeats and region.repeatsOver and region.repeatsOver not in repeat_entities %}
{% set _ = repeat_entities.append(region.repeatsOver) %}
{% endif %}
{% endfor %}
{% for ent in repeat_entities %}
  const {{ ent }}_data = state['{{ ent }}'] || state['{{ ent }}s'] || [];
{% endfor %}

  // Deterministic edge-state switch: ?state=<variant> forces any declared
  // variant so an agent/tester can reach every state without special data.
{% for variant in screen.variants %}
{% if variant.kind != 'default' %}
  if (currentState === '{{ variant.kind }}') {
    return <div data-testid="{{ variant.kind }}-state" className="min-h-screen bg-background flex items-center justify-center text-gray-500">{ {{ (variant.description or (variant.kind ~ ' state')) | tojson }} }</div>;
  }
{% endif %}
{% endfor %}

  // Default (happy path): render each layout region and its components.
  return (
    <div data-testid="{{ screen.id }}-screen" className="min-h-screen bg-background py-4">
{% set tag_map = {'header': 'header', 'nav': 'nav', 'sidebar': 'aside', 'main': 'main', 'footer': 'footer', 'modal': 'div'} %}
{% for region in regions %}
{% set tag = tag_map.get(region.name, 'div') %}
      <{{ tag }} data-testid="{{ region.name }}-region" className="max-w-3xl mx-auto bg-surface shadow-sm">
{% if region.repeats and region.repeatsOver %}
        { {{ region.repeatsOver }}_data.map((item) => (
          <Fragment key={item.id}>
{% for c in region.components or [] %}
{% if c in component_names %}
            <{{ c }} key={item.id} {...item} />
{% endif %}
{% endfor %}
          </Fragment>
        ))}
{% else %}
{% for c in region.components or [] %}
{% if c in component_names %}
        <{{ c }} />
{% endif %}
{% endfor %}
{% endif %}
      </{{ tag }}>
{% endfor %}
    </div>
  );
}
