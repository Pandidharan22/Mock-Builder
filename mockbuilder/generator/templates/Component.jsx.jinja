{# Auto-generated by MockBuilder from the AppModel. Do not edit by hand. #}
{% set elements = component.interactiveElements or [] %}
{% set cn = component.name | lower %}
{% set ns = namespace(has_mutation=false, has_navigation=false) %}
{% for el in elements %}
{% set act = el.action %}
{% if act and act.type in ['mutateState', 'navigateAndMutate'] and act.mutation %}
{% set ns.has_mutation = true %}
{% endif %}
{% if act and act.type in ['navigate', 'navigateAndMutate'] and act.targetScreen and screen_routes.get(act.targetScreen) %}
{% set ns.has_navigation = true %}
{% endif %}
{% endfor %}
{% if ns.has_navigation %}
import { useNavigate } from 'react-router-dom';
{% endif %}
{% if ns.has_mutation %}
import { useMockState } from '../GlobalContext';
{% endif %}
{#- Render one interactive element (with data-testid + wired handler) using the
    supplied className. Centralizes the per-element JSX so the layout below can
    place elements into semantic rows. -#}
{% macro render_el(el, cls) -%}
{%- if '{id}' in el.testId -%}
{%- set testid_attr = 'data-testid={`' ~ el.testId.replace('{id}', '${props.id}') ~ '`}' -%}
{%- else -%}
{%- set testid_attr = 'data-testid="' ~ el.testId ~ '"' -%}
{%- endif -%}
{%- set display_label = el.label if el.label else el.testId.replace('-{id}', '').replace('{id}', '') -%}
{%- set act = el.action -%}
{%- set hb = namespace(parts=[]) -%}
{%- if act and act.type in ['mutateState', 'navigateAndMutate'] and act.mutation -%}
{%- set mut = act.mutation -%}
{%- set payload = mut.payloadFrom | payload_expr -%}
{%- set _ = hb.parts.append("mutate({ type: '" ~ mut.op ~ "', store: '" ~ mut.store ~ "', payload: " ~ payload ~ " })") -%}
{%- endif -%}
{%- if act and act.type in ['navigate', 'navigateAndMutate'] and act.targetScreen and screen_routes.get(act.targetScreen) -%}
{%- set _ = hb.parts.append("navigate(" ~ (screen_routes.get(act.targetScreen) | nav_target) ~ ")") -%}
{%- endif -%}
{%- set handler = 'onChange' if el.kind in ['input', 'select'] else 'onClick' -%}
{%- set handler_attr = (' ' ~ handler ~ '={() => { ' ~ (hb.parts | join('; ')) ~ '; }}') if hb.parts else '' -%}
{%- if el.kind == 'input' -%}
<input {{ testid_attr }} placeholder={ {{ display_label | label_expr }} } className="{{ cls }}"{{ handler_attr }} />
{%- elif el.kind == 'select' -%}
<select {{ testid_attr }} className="{{ cls }}"{{ handler_attr }}><option>{ {{ display_label | label_expr }} }</option></select>
{%- elif el.kind == 'link' -%}
<a {{ testid_attr }} className="{{ cls }}"{{ handler_attr }}>{ {{ display_label | label_expr }} }</a>
{%- else -%}
<button {{ testid_attr }} className="{{ cls }}"{{ handler_attr }}>{ {{ display_label | label_expr }} }</button>
{%- endif -%}
{%- endmacro %}
{#- Render a data field whose type is imageUrl as an <img> (type-driven, never
    name-matched). An empty/missing value renders a neutral light-gray placeholder
    box — visually distinct from a real photo, never a broken-image icon or
    "undefined". Alt text comes from real data (see classify_component). -#}
{% macro render_image(name, cn, alt) -%}
{props.{{ name }} ? (
            <img data-testid="{{ cn }}-{{ name }}" src={props.{{ name }}} alt={ {{ alt }} } className="w-20 h-20 object-cover rounded flex-shrink-0" />
          ) : (
            <div data-testid="{{ cn }}-{{ name }}" className="w-20 h-20 bg-gray-100 border border-gray-200 rounded flex-shrink-0" aria-hidden="true" />
          )}
{%- endmacro %}

// {{ component.name }}{% if component.role %} - {{ component.role }}{% endif %}

export default function {{ component.name }}(props) {
{% if ns.has_navigation %}
  const navigate = useNavigate();
{% endif %}
{% if ns.has_mutation %}
  const { mutate } = useMockState();
{% endif %}
{% if component.boundToEntity %}
  {# --- Entity row: semantic visual hierarchy driven by prop uiHints. --- #}
  return (
    <div data-testid="{{ cn }}" className="flex gap-3 py-2 px-4 border-b border-gray-100 hover:bg-gray-50">
{% if hierarchy.vote_elements %}
      <div data-testid="{{ cn }}-vote" className="flex flex-col items-center text-gray-400 pt-1">
{% for el in hierarchy.vote_elements %}
        {{ render_el(el, 'text-primary hover:opacity-80 cursor-pointer leading-none') }}
{% endfor %}
      </div>
{% endif %}
      <div className="flex flex-col flex-1 min-w-0">
        <div data-testid="{{ cn }}-primary" className="flex items-baseline gap-2 flex-wrap">
{% for el in hierarchy.title_elements %}
          {{ render_el(el, 'text-base font-medium text-gray-900 hover:text-primary hover:underline cursor-pointer') }}
{% endfor %}
{% for f in hierarchy.title_fields %}
{% if hierarchy.field_types.get(f) == 'imageUrl' %}
          {{ render_image(f, cn, hierarchy.image_alt) }}
{% else %}
          <span data-testid="{{ cn }}-{{ f }}" className="text-base font-medium text-gray-900">{props.{{ f }} || ''}</span>
{% endif %}
{% endfor %}
        </div>
{% if hierarchy.content_fields %}
        <div data-testid="{{ cn }}-content" className="text-sm text-gray-700 mt-1">
{% for f in hierarchy.content_fields %}
{% if hierarchy.field_types.get(f) == 'imageUrl' %}
          {{ render_image(f, cn, hierarchy.image_alt) }}
{% else %}
          <span data-testid="{{ cn }}-{{ f }}">{props.{{ f }} || ''}</span>
{% endif %}
{% endfor %}
        </div>
{% endif %}
        <div data-testid="{{ cn }}-meta" className="flex flex-wrap items-center gap-3 text-xs text-gray-500 mt-1">
{% for f in hierarchy.metadata_fields %}
{% if hierarchy.field_types.get(f) == 'imageUrl' %}
          {{ render_image(f, cn, hierarchy.image_alt) }}
{% else %}
          <span data-testid="{{ cn }}-{{ f }}">{props.{{ f }} || ''}</span>
{% endif %}
{% endfor %}
{% for el in hierarchy.action_elements %}
          {{ render_el(el, 'hover:text-primary hover:underline cursor-pointer') }}
{% endfor %}
        </div>
      </div>
    </div>
  );
{% else %}
  {# --- Chrome component (nav/footer): simple inline row. --- #}
  return (
    <div data-testid="{{ cn }}" className="flex flex-wrap items-center gap-4 py-3 px-4 border-b border-gray-200 bg-surface text-sm">
{% for el in elements %}
      {{ render_el(el, 'text-gray-700 hover:text-primary hover:underline cursor-pointer') }}
{% endfor %}
    </div>
  );
{% endif %}
}
